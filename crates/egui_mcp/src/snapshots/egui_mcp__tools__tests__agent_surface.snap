}

## query_tree

{
  "name": "query_tree",
  "description": "Walk the widget tree and return nodes matching the filter.\n`role`, if given, is a role name (e.g. `Button`, `Label`), matched case-insensitively; an unknown role errors with the roles present in the tree.\nUse the returned `id` with `click`, `type_text`, or `get_node`.",
  "inputSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
      "label_contains": {
        "type": [
          "string",
          "null"
        ]
      },
      "limit": {
        "default": 200,
        "format": "uint",
        "minimum": 0,
        "type": "integer"
      },
      "role": {
        "description": "Role name, e.g. `Button`, `Label`, `TextInput` (case-insensitive).\nAn unrecognized role is rejected with an error that lists the roles present in the tree.",
        "type": [
          "string",
          "null"
        ]
      },
      "visible_only": {
        "default": true,
        "type": "boolean"
      }
    },
    "title": "QueryFilter",
    "type": "object"
  },
  "outputSchema": {
    "$defs": {
      "NodeView": {
        "properties": {
          "bounds": {
            "anyOf": [
              {
                "$ref": "#/$defs/RectF"
              },
              {
                "type": "null"
              }
            ]
          },
          "disabled": {
            "type": "boolean"
          },
          "focused": {
            "type": "boolean"
          },
          "hidden": {
            "type": "boolean"
          },
          "id": {
            "description": "Node id, used with `click`, `type_text`, and `get_node`.",
            "type": "string"
          },
          "label": {
            "type": [
              "string",
              "null"
            ]
          },
          "parent_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "role": {
            "type": "string"
          },
          "value": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "id",
          "role",
          "focused",
          "disabled",
          "hidden"
        ],
        "type": "object"
      },
      "RectF": {
        "properties": {
          "h": {
            "format": "double",
            "type": "number"
          },
          "w": {
            "format": "double",
            "type": "number"
          },
          "x": {
            "format": "double",
            "type": "number"
          },
          "y": {
            "format": "double",
            "type": "number"
          }
        },
        "required": [
          "x",
          "y",
          "w",
          "h"
        ],
        "type": "object"
      }
    },
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "`query_tree` result: the matching nodes.",
    "properties": {
      "nodes": {
        "items": {
          "$ref": "#/$defs/NodeView"
        },
        "type": "array"
      }
    },
    "required": [
      "nodes"
    ],
    "title": "QueryTreeResult",
    "type": "object"
  }
}

